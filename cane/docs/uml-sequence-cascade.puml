@startuml CandyCrushCascadeSequence
title Candy Crush — Cascade Flow on Player Swap

actor Player
participant ":GameView" as V
participant ":GameController" as C
participant ":Board" as B
participant ":ScoreManager" as S
participant ":AnimationManager" as A
participant "state:GameState" as ST

Player -> V : click cellA, click cellB
V -> C : handleCellClick(cell)
C -> C : attemptSwap(a, b)
C -> A : playSwap(paneA, paneB, cb)
A --> C : cb()
C -> B : swap(a, b)
C -> B : resolveMatches(a, b, true)
B --> C : MatchResolution

alt resolution.isEmpty
  C -> B : swap(a, b)  // revert
  C -> A : playSwapBack(paneA, paneB, cb)
  A --> C : cb()
  C -> V : setStatusText("Invalid move!")
else has matches
  loop while resolution not empty
    C -> A : playRemoval(panes, cb)
    A --> C : cb()
    C -> B : applyMatchResolution(r)
    C -> S : addScore(cleared + spawns)
    C -> B : applyGravity()
    C -> B : fillEmpty()
    C -> V : renderBoard()
    C -> A : playGravity(drops, cb)
    A --> C : cb()
    C -> A : playSpawn(panes, rows, cb)
    A --> C : cb()
    C -> B : resolveMatches(null, null, false)
    B --> C : nextResolution
  end
  C -> S : useMove()
  alt isGameOver
    C -> ST : transitionTo(gameOverState)
    ST -> V : setStatusText("Game Over! Final Score: ...")
  end
end

@enduml
