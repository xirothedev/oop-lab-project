<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.LeaderboardController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <center>
        <TableView fx:id="leaderboardTable" prefHeight="360" prefWidth="460">
            <columns>
                <TableColumn fx:id="playerColumn" prefWidth="150" text="Player"/>
                <TableColumn fx:id="scoreColumn" prefWidth="120" text="Score"/>
                <TableColumn fx:id="levelColumn" prefWidth="180" text="Level"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <Button onAction="#handleBack" text="Back"/>
        </HBox>
    </bottom>
</BorderPane>

