<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="20" stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.HomeController">
    <padding>
        <Insets top="40" right="40" bottom="24" left="40"/>
    </padding>
    <Label styleClass="home-title" text="Candy Crush"/>
    <Label styleClass="subtitle" text="OOP Lab — JavaFX Edition"/>
    <Region prefHeight="12"/>
    <Button onAction="#handlePlay" text="Start Game"/>
    <Button onAction="#handleLeaderboard" text="Leaderboard"/>
    <Button onAction="#handleHelp" text="Help and Rules"/>
    <Region VBox.vgrow="ALWAYS"/>
    <Label styleClass="home-version" text="v1.0.0"/>
</VBox>
