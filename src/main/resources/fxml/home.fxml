<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.HomeController">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>
    <Label styleClass="title" text="Candy Crush OOP Lab"/>
    <Label styleClass="subtitle" text="JavaFX edition with testable game logic"/>
    <Button onAction="#handlePlay" text="Start Game"/>
    <Button onAction="#handleLeaderboard" text="Leaderboard"/>
    <Button onAction="#handleHelp" text="Help and Rules"/>
    <Button onAction="#handleExit" text="Exit"/>
</VBox>

