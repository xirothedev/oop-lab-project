<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.LevelSelectController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>
    <top>
        <Label styleClass="title" text="Select Level"/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background: transparent; -fx-border-color: transparent;">
            <VBox fx:id="levelCardContainer" spacing="12"/>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button onAction="#handleBack" styleClass="button-secondary" text="Back"/>
            <Button fx:id="playButton" onAction="#handleStart" text="Play"/>
        </HBox>
    </bottom>
</BorderPane>
