<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.LevelSelectController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <top>
        <Label styleClass="title" text="Select a Level"/>
    </top>
    <center>
        <HBox spacing="18">
            <ListView fx:id="levelList" prefHeight="320" prefWidth="220"/>
            <VBox spacing="12">
                <Label styleClass="section-title" text="Level details"/>
                <Label fx:id="levelSummary" prefWidth="260" wrapText="true"/>
            </VBox>
        </HBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button onAction="#handleBack" text="Back"/>
            <Button onAction="#handleStart" text="Play"/>
        </HBox>
    </bottom>
</BorderPane>

