<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ooplab.candycrush.ui.GameController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>
    <top>
        <VBox spacing="8">
            <Label fx:id="levelNameLabel" styleClass="title" text="Level"/>
            <HBox spacing="18">
                <Label fx:id="scoreLabel" text="Score: 0"/>
                <Label fx:id="movesLabel" text="Moves: 0"/>
                <Label fx:id="goalLabel" text="Goal:"/>
            </HBox>
            <Label fx:id="hintLabel" styleClass="subtitle" text="Select two adjacent candies to swap."/>
        </VBox>
    </top>
    <center>
        <GridPane fx:id="boardGrid"/>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button onAction="#handleBack" text="Back"/>
            <Button onAction="#handleRestart" text="Restart"/>
        </HBox>
    </bottom>
</BorderPane>

